{
  "expo": {
    "name": "Tempo",
    "slug": "tempo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tempo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.tempo.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCalendarsUsageDescription": "Tempo uses your calendar to schedule workouts around your life.",
        "NSRemindersUsageDescription": "Tempo sends reminders before your scheduled workouts.",
        "NSUserNotificationsUsageDescription": "Tempo sends reminders before your scheduled workouts."
      }
    },
    "android": {
      "package": "com.tempo.app",

      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-calendar",
        {
          "calendarPermission": "Tempo needs calendar access to schedule your workouts.",
          "remindersPermission": "Tempo needs reminder access to send workout alerts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3B82F6",
          "defaultChannel": "workouts"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0A",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bdb2dc2b-4340-4191-8a7f-4411fb56734f"
      }
    }
  }
}
